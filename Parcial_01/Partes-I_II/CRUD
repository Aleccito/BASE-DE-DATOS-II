-- READ: Consulta filtrada de usuarios activos con rol Cliente
SELECT u.id, u.nombre, u.apellido, u.correo, r.descripcion AS rol
FROM Usuarios u
JOIN Roles r ON u.id_rol = r.id
WHERE u.activo = 1
AND r.descripcion = 'Cliente';

